# ──────────────────────────────────────────────────────────────
# frontend/.env.production — siparbox.com için production ayarları
# ──────────────────────────────────────────────────────────────

# Backend API URL'i
VITE_BACKEND_SERVER=https://siparbox.com/

# Yüklenen dosyaların base URL'i
VITE_FILE_BASE_URL=https://siparbox.com/

# Production modunu aktif et
PROD=true
