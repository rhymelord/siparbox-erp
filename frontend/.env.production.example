# ──────────────────────────────────────────────────────────────
# frontend/.env.production.example
# Sunucuda .env.production adıyla kopyalayıp doldurun:
#   cp .env.production.example .env.production
# ──────────────────────────────────────────────────────────────

# Backend API URL'i (domain aldıktan sonra güncelleyin)
# Şimdilik: http://SUNUCU_IP_ADRESINIZ/
VITE_BACKEND_SERVER=https://siparbox.com/

# Yüklenen dosyaların base URL'i (backend ile aynı)
VITE_FILE_BASE_URL=https://siparbox.com/

# Production modunu aktif et
PROD=true
