# ──────────────────────────────────────────────────────────────
# backend/.env.example
# Sunucuda .env adıyla kopyalayıp değerleri doldurun:
#   cp .env.example .env
# ──────────────────────────────────────────────────────────────

# MongoDB bağlantı adresi (docker-compose ile aynı ağdaysa bu şekilde kalır)
DATABASE=mongodb://mongo:27017/eyetech-erp

# JWT şifreleme anahtarı (güçlü ve rastgele bir string girin!)
# Örnek üretmek için: openssl rand -base64 32
JWT_SECRET=eyetechltdsti1234567890secretkey

# Ortam (production olarak bırakın)
NODE_ENV=production

# Sunucunuzun public URL'i
PUBLIC_SERVER_FILE=https://siparbox.com/

# Uygulama portu (değiştirmenize gerek yok)
PORT=8888

# ─── Opsiyonel Servisler ───────────────────────────────────────

# E-posta gönderimi için Resend API anahtarı (https://resend.com - ücretsiz)
# RESEND_API=re_xxxxxxxxxxxx

# OpenAI entegrasyonu için (opsiyonel)
# OPENAI_API_KEY=sk-xxxxxxxxxxxx

# AWS S3 dosya depolama (opsiyonel, şimdilik gerekmiyor)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=eu-central-1
# S3_BUCKET=
